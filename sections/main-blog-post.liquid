

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    <header>
      {%- content_for 'block', id: 'blog-post-title', type: 'text' %}
      {%- content_for 'block', id: 'blog-post-details', type: '_blog-post-info-text' %}
    </header>

    <div class="blog-post-layout" data-article-toc>
      <aside class="blog-post-toc" aria-labelledby="blog-post-toc-title" hidden>
        <p id="blog-post-toc-title" class="blog-post-toc__title">In this article</p>
        <nav aria-label="Article sections">
          <ol class="blog-post-toc__list" data-article-toc-list></ol>
        </nav>
      </aside>

      <div class="blog-post-layout__content" data-article-body>
        {%- if article.image -%}
          {%- content_for 'block', id: 'blog-post-image', type: '_blog-post-featured-image' %}
        {%- endif -%}
        {%- content_for 'block', id: 'blog-post-content', type: '_blog-post-content' %}
      </div>
    </div>

    {% liquid
      assign shop_the_article_products = article.metafields.custom.shop_the_article.value
    %}
    {% if shop_the_article_products != blank %}
      <section class="shop-the-article" aria-labelledby="shop-the-article-title">
        <div class="shop-the-article__header">
          <p>Featured products</p>
          <h2 id="shop-the-article-title">Shop the article</h2>
        </div>

        <div class="shop-the-article__grid">
          {% for product in shop_the_article_products limit: 4 %}
            {% liquid
              assign variant = product.selected_or_first_available_variant
            %}
            <article class="shop-the-article__card">
              <a href="{{ product.url }}" class="shop-the-article__media" aria-label="{{ product.title | escape }}">
                {% if product.featured_image %}
                  {% assign product_image_alt = product.featured_image.alt | default: product.title %}
                  {{
                    product.featured_image
                    | image_url: width: 700
                    | image_tag:
                      widths: '240, 360, 480, 700',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                      loading: 'lazy',
                      alt: product_image_alt
                  }}
                {% endif %}
              </a>

              <div class="shop-the-article__content">
                <a href="{{ product.url }}" class="shop-the-article__title">{{ product.title }}</a>
                <span class="shop-the-article__price">{{ product.price | money_with_currency }}</span>

                {% if variant.available %}
                  {% form 'product', product, class: 'shop-the-article__form' %}
                    <input type="hidden" name="id" value="{{ variant.id }}">
                    <button type="submit" class="button shop-the-article__button">
                      Add to cart
                    </button>
                  {% endform %}
                {% else %}
                  <a href="{{ product.url }}" class="button button-secondary shop-the-article__button">View product</a>
                {% endif %}
              </div>
            </article>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {% comment %} Dynamic area for @app blocks only, at the bottom {% endcomment %}
    {% content_for 'blocks' %}

    {% if blog.comments_enabled? %}
      <div class="blog-post-comments-container">
        <h2 class="h3">{{- 'blogs.article.comments_heading' | t: count: article.comments_count -}}</h2>

        <div class="blog-post-comments">
          {% paginate article.comments by 10 %}
            {% for comment in article.comments %}
              <div class="blog-post-comment">
                {{ comment.content }}
                <div class="blog-post-comment__author">
                  <span class="blog-post-comment__author-name">{{- comment.author -}}</span>
                  <span>{{- 'blogs.article.comment_author_separator' | t -}}</span>
                  <span class="blog-post-comment__date">
                    {{- comment.created_at | time_tag: format: 'date' -}}
                  </span>
                </div>
              </div>
            {% endfor %}

            <div class="blog-post-comments-pagination">
              {{- paginate | default_pagination -}}
            </div>
          {% endpaginate %}
        </div>

        {% render 'blog-comment-form', article: article, section_id: section.id %}
      </div>
    {% endif %}
  </div>
</div>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

<script>
  (() => {
    const initArticleToc = () => {
      document.querySelectorAll('[data-article-toc]').forEach((articleLayout) => {
        const body = articleLayout.querySelector('[data-article-body]');
        const toc = articleLayout.querySelector('.blog-post-toc');
        const list = articleLayout.querySelector('[data-article-toc-list]');

        if (!body || !toc || !list) return;

        const headings = Array.from(body.querySelectorAll('.blog-post-content h2')).filter((heading) =>
          heading.textContent.trim()
        );

        if (!headings.length) return;

        list.replaceChildren();

        const tocLinks = [];

        headings.forEach((heading, index) => {
          if (!heading.id) {
            const slug = heading.textContent
              .trim()
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, '-')
              .replace(/^-|-$/g, '');

            heading.id = `article-${slug || 'section'}-${index + 1}`;
          }

          const item = document.createElement('li');
          const link = document.createElement('a');

          link.href = `#${heading.id}`;
          link.textContent = heading.textContent.trim();
          item.append(link);
          list.append(item);
          tocLinks.push(link);
        });

        toc.hidden = false;

        tocLinks.forEach((link) => {
          link.addEventListener('click', (event) => {
            const target = document.getElementById(decodeURIComponent(link.hash.slice(1)));

            if (!target) return;

            event.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, '', link.hash);
          });
        });

        const setActiveLink = (activeHeading) => {
          tocLinks.forEach((link) => {
            const isActive = link.hash === `#${activeHeading.id}`;
            link.classList.toggle('is-active', isActive);

            if (isActive) {
              link.setAttribute('aria-current', 'true');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        setActiveLink(headings[0]);

        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver(
            (entries) => {
              const visibleHeadings = entries
                .filter((entry) => entry.isIntersecting)
                .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

              if (visibleHeadings[0]) {
                setActiveLink(visibleHeadings[0].target);
              }
            },
            {
              rootMargin: '-20% 0px -65% 0px',
              threshold: 0,
            }
          );

          headings.forEach((heading) => observer.observe(heading));
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initArticleToc, { once: true });
    } else {
      initArticleToc();
    }
  })();
</script>

{% stylesheet %}
  .blog-post-layout {
    display: grid;
    grid-template-columns: minmax(10rem, 13rem) minmax(0, var(--normal-content-width));
    justify-content: center;
    align-items: start;
    gap: var(--gap-2xl);
    width: 100%;
  }

  .blog-post-layout__content {
    min-width: 0;
  }

  .blog-post-layout__content .blog-post-featured-image {
    margin-block-end: var(--margin-xl);
  }

  .blog-post-toc {
    position: sticky;
    top: calc(var(--header-height, var(--sticky-header-offset, 0px)) + var(--padding-lg));
    align-self: start;
    max-height: calc(100vh - var(--header-height, 0px) - var(--padding-2xl));
    overflow-y: auto;
    width: 100%;
    padding-block-start: var(--padding-sm);
    font-size: var(--font-size--body-sm);
  }

  .blog-post-toc[hidden] {
    display: none;
  }

  .blog-post-toc__title {
    margin: 0 0 var(--margin-xs);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: var(--font-size--body-sm);
    font-weight: 700;
    text-transform: uppercase;
  }

  .blog-post-toc__list {
    display: grid;
    gap: var(--gap-xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .blog-post-toc__list a {
    color: rgb(var(--color-foreground-rgb) / 0.72);
    text-decoration: none;
  }

  .blog-post-toc__list a:hover {
    color: var(--color-primary);
  }

  .blog-post-toc__list a.is-active,
  .blog-post-toc__list a[aria-current='true'] {
    color: var(--color-foreground);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .blog-post-layout .blog-post-content h2 {
    scroll-margin-block-start: calc(var(--header-height, 0px) + var(--padding-xl));
  }

  .blog-post-comments-container {
    width: 100%;
    max-width: var(--normal-content-width);
    margin: 0 auto;
  }

  .blog-post-comments {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xl);
  }

  .blog-post-comment__author {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    margin-top: var(--margin-md);
    font-size: var(--font-size--body-sm);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .blog-post-comments-pagination {
    display: flex;
    justify-content: center;
    gap: var(--gap-2xs);
  }

  .blog-post-comments-pagination,
  .blog-post-comments-pagination a {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current {
    color: var(--color-foreground);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a {
    display: block;
    padding: var(--padding-2xs) var(--padding-xs);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a:hover {
    border-bottom: 1px solid var(--color-foreground);
  }

  .shop-the-article {
    width: 100%;
    max-width: var(--wide-content-width);
    margin: var(--margin-3xl) auto 0;
    padding-block-start: var(--padding-xl);
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.14);
  }

  .shop-the-article__header {
    display: grid;
    gap: var(--gap-2xs);
    margin-block-end: var(--margin-lg);
  }

  .shop-the-article__header p,
  .shop-the-article__header h2 {
    margin: 0;
  }

  .shop-the-article__header p {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: var(--font-size--body-sm);
    text-transform: uppercase;
  }

  .shop-the-article__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--gap-lg);
  }

  .shop-the-article__card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .shop-the-article__media {
    aspect-ratio: 1 / 1;
    display: block;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.04);
  }

  .shop-the-article__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .shop-the-article__content {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: var(--gap-2xs);
    padding-block-start: var(--padding-sm);
  }

  .shop-the-article__title {
    color: inherit;
    text-decoration: none;
  }

  .shop-the-article__price {
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    font-size: var(--font-size--body-sm);
  }

  .shop-the-article__form {
    margin-block-start: auto;
    padding-block-start: var(--padding-sm);
  }

  .shop-the-article__button {
    margin-block-start: auto;
    width: 100%;
  }

  @media screen and (max-width: 989px) {
    .blog-post-layout {
      grid-template-columns: minmax(0, var(--normal-content-width));
    }

    .blog-post-toc {
      position: sticky;
      padding: var(--padding-md);
      border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
      background: rgb(var(--color-background-rgb));
      z-index: 1;
    }

    .shop-the-article__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .shop-the-article__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_post",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "class": "section-wrapper",
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
