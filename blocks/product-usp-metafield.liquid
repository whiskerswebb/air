{% liquid
  assign block_settings = block.settings
  assign metafield_value = blank

  case block_settings.metafield_key
    when 'pdp_usp_1'
      assign metafield_value = closest.product.metafields.custom.pdp_usp_1.value
    when 'pdp_usp_2'
      assign metafield_value = closest.product.metafields.custom.pdp_usp_2.value
    when 'pdp_usp_3'
      assign metafield_value = closest.product.metafields.custom.pdp_usp_3.value
    when 'best_for'
      assign metafield_value = closest.product.metafields.custom.best_for.value
    when 'care_note'
      assign metafield_value = closest.product.metafields.custom.care_note.value
    when 'shipping_note'
      assign metafield_value = closest.product.metafields.custom.shipping_note.value
  endcase

  assign fallback_text = block_settings.text
%}

{% capture resolved_text %}
  {% if metafield_value != blank %}
    {% if block_settings.emphasize %}
      <p><strong>{{ metafield_value | escape }}</strong></p>
    {% else %}
      <p>{{ metafield_value | escape }}</p>
    {% endif %}
  {% else %}
    {{ fallback_text }}
  {% endif %}
{% endcapture %}

{% if resolved_text != blank %}
  <rte-formatter
    class="spacing-style text-block text-block--{{ block.id }} custom-typography custom-font-size product-usp-metafield"
    style="
      {% render 'spacing-padding', settings: block_settings %}
      {% render 'typography-style', settings: block_settings %}
      --width: {{ block_settings.width }};
      --max-width: var(--max-width--body-{{ block_settings.max_width }});
      --text-align: {{ block_settings.alignment }};
    "
    {{ block.shopify_attributes }}
  >
    {{ resolved_text | strip }}
  </rte-formatter>
{% endif %}

{% schema %}
{
  "name": "Product USP metafield",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "metafield_key",
      "label": "Product metafield",
      "options": [
        {
          "value": "pdp_usp_1",
          "label": "PDP USP 1"
        },
        {
          "value": "pdp_usp_2",
          "label": "PDP USP 2"
        },
        {
          "value": "pdp_usp_3",
          "label": "PDP USP 3"
        },
        {
          "value": "best_for",
          "label": "Best for"
        },
        {
          "value": "care_note",
          "label": "Care note"
        },
        {
          "value": "shipping_note",
