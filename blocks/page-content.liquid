{% liquid
  assign page_title_downcase = page.title | downcase
  assign is_faq_page = false

  if page.handle contains 'faq' or page_title_downcase contains 'faq'
    assign is_faq_page = true
  endif
%}

{% if is_faq_page %}
  <faq-page-content class="faq-page-content">
    <rte-formatter>
      {{ page.content }}
    </rte-formatter>
  </faq-page-content>

  <script
    type="module"
    src="{{ 'faq-page-content.js' | asset_url }}"
    fetchpriority="low"
  ></script>
{% else %}
  <rte-formatter>
    {{ page.content }}
  </rte-formatter>
{% endif %}

{% stylesheet %}
  .faq-page-content {
    display: block;
    width: 100%;
  }

  .faq-page-content__list {
    display: grid;
    gap: var(--gap-xs);
  }

  .faq-page-content__item {
    border-block-end: var(--style-border-width) solid var(--color-border);
  }

  .faq-page-content__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    padding-block: var(--padding-md);
    cursor: pointer;
    font-weight: var(--font-weight-semibold, 600);
    list-style: none;
  }

  .faq-page-content__summary::-webkit-details-marker {
    display: none;
  }

  .faq-page-content__summary::after {
    content: '+';
    flex: 0 0 auto;
    font-size: var(--font-size--lg);
    line-height: 1;
  }

  .faq-page-content__item[open] .faq-page-content__summary::after {
    content: '-';
  }

  .faq-page-content__panel {
    padding-block: 0 var(--padding-lg);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .faq-page-content__panel > :first-child {
    margin-block-start: 0;
  }

  .faq-page-content__panel > :last-child {
    margin-block-end: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.page_content",
  "class": "rte"
}
{% endschema %}
