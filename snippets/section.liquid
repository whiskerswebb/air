{%- doc -%}
  Renders a wrapper section

  @param {section} section - The section object
  @param {string} children - The children of the section
{%- enddoc -%}

{% liquid
  assign is_collection_hero = false
  if request.page_type == 'collection' and section.id contains 'section'
    assign is_collection_hero = true
  endif

  assign is_starter_feature = false
  if section.id contains 'starter_feature'
    assign is_starter_feature = true
  endif

  assign is_problem_solution = false
  if section.id contains 'problem_solution'
    assign is_problem_solution = true
  endif
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}{% if is_collection_hero %} section--collection-hero{% endif %}{% if is_starter_feature %} section--starter-feature{% endif %}{% if is_problem_solution %} section--problem-solution{% endif %}"
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}

  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}

    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}
  "
>
  <div class="custom-section-background">
    {% if is_collection_hero %}
      <div class="background-image-container">
        {% if collection.image != blank %}
          {{
            collection.image
            | image_url: width: 2400
            | image_tag:
              sizes: '100vw',
              widths: '832, 1200, 1600, 1920, 2400',
              loading: 'eager',
              fetchpriority: 'high'
          }}
        {% else %}
          <img
            src="{{ 'home-freshspace-hero.jpg' | asset_url }}"
            alt=""
            width="1866"
            height="1200"
            loading="eager"
            fetchpriority="high"
          >
        {% endif %}
      </div>
    {% else %}
      {% render 'background-media',
        background_media: section.settings.background_media,
        background_video: section.settings.video,
        background_video_position: section.settings.video_position,
        background_image: section.settings.background_image,
        background_image_position: section.settings.background_image_position
      %}
    {% endif %}
  </div>

  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    {% if section.settings.toggle_overlay or is_collection_hero %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
      data-testid="section-content"
    >
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .section[data-shopify-visual-preview] {
    min-height: var(--section-preview-height);
    padding-top: 0;
  }

  .section[data-shopify-visual-preview] .custom-section-background {
    display: none;
  }

  body:has(> #header-group > .header-section > #header-component[transparent]):not(
      :has(> #header-group > .header-section + .shopify-section)
    )
    > main
    > .section-wrapper:first-child {
    --section-height-offset: var(--header-group-height, 0);
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  .section--collection-hero {
    min-height: clamp(300px, 42svh, 460px);
    color: var(--color-foreground);
  }

  .section--collection-hero .overlay {
    --overlay-color: #0000008a !important;
  }

  .section--collection-hero .custom-section-background,
  .section--collection-hero .background-image-container,
  .section--collection-hero .background-image-container img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .section--collection-hero .background-image-container img {
    object-fit: cover;
    object-position: center;
  }

  .section--collection-hero .custom-section-content,
  .section--collection-hero .section-content-wrapper {
    min-height: inherit;
  }

  .section--collection-hero .section-content-wrapper {
    justify-content: center;
  }

  .collection-hero__copy {
    display: grid;
    gap: var(--gap-xs);
    max-width: min(42rem, 100%);
    color: #fff;
  }

  .collection-hero__copy h1,
  .collection-hero__copy p {
    margin: 0;
  }

  .collection-hero__copy p:empty {
    display: none;
  }

  .collection-hero__copy h1 {
    color: #fff;
  }

  .collection-hero__copy > p:not(.collection-hero__eyebrow) {
    max-width: 36rem;
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.45;
  }

  .collection-hero__eyebrow {
    font-size: 0.78rem;
    font-weight: var(--font-weight-semibold, 600);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.88;
  }

  .section--collection-hero .section-content-wrapper > .group-block:last-child .group-block-content {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-sm) var(--gap-lg);
  }

  .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: auto;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: #fff;
    font-size: 0.9rem;
    font-weight: var(--font-weight-semibold, 600);
    line-height: 1.15;
    opacity: 0.92;
  }

  .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block::before {
    content: '';
    flex: 0 0 auto;
    width: 1.35rem;
    height: 1.35rem;
    background-color: currentColor;
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
  }

  .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block:nth-child(1)::before {
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 10.5 12 3l9 7.5'/%3E%3Cpath d='M5.5 9.5V21h13V9.5'/%3E%3Cpath d='M9 21v-6h6v6'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 10.5 12 3l9 7.5'/%3E%3Cpath d='M5.5 9.5V21h13V9.5'/%3E%3Cpath d='M9 21v-6h6v6'/%3E%3C/svg%3E");
  }

  .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block:nth-child(2)::before {
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 7v5h-5'/%3E%3Cpath d='M4 17v-5h5'/%3E%3Cpath d='M18.2 11A6.5 6.5 0 0 0 7.1 7.4L4 10'/%3E%3Cpath d='M5.8 13A6.5 6.5 0 0 0 16.9 16.6L20 14'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 7v5h-5'/%3E%3Cpath d='M4 17v-5h5'/%3E%3Cpath d='M18.2 11A6.5 6.5 0 0 0 7.1 7.4L4 10'/%3E%3Cpath d='M5.8 13A6.5 6.5 0 0 0 16.9 16.6L20 14'/%3E%3C/svg%3E");
  }

  .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block:nth-child(3)::before {
    -webkit-mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z'/%3E%3Cpath d='m9 12 2 2 4-4'/%3E%3C/svg%3E");
    mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%23000' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z'/%3E%3Cpath d='m9 12 2 2 4-4'/%3E%3C/svg%3E");
  }

  .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block p {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .section--collection-hero {
      min-height: 320px;
    }

    .section--collection-hero .section-content-wrapper {
      gap: var(--gap-md);
      padding-block: 34px 30px;
    }

    .collection-hero__copy {
      gap: 0.45rem;
    }

    .collection-hero__copy h1 {
      font-size: clamp(2.7rem, 13vw, 4rem);
      line-height: 0.95;
    }

    .collection-hero__copy > p:not(.collection-hero__eyebrow) {
      max-width: 32rem;
      font-size: 1rem;
      line-height: 1.32;
    }

    .collection-hero__eyebrow {
      font-size: 0.68rem;
      letter-spacing: 0.08em;
    }

    .section--collection-hero .section-content-wrapper > .group-block:last-child .group-block-content {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
      gap: 0.65rem 0.9rem;
    }

    .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
      gap: 0.4rem;
      min-width: 0;
      width: 100%;
      font-size: 0.72rem;
      line-height: 1.15;
    }

    .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block::before {
      width: 0.9rem;
      height: 0.9rem;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .section--collection-hero {
      min-height: 360px;
    }

    .section--collection-hero .section-content-wrapper {
      gap: var(--gap-md);
      padding-block: 40px 34px;
    }

    .collection-hero__copy {
      gap: 0.5rem;
      max-width: 34rem;
    }

    .collection-hero__copy h1 {
      font-size: clamp(3.25rem, 8vw, 4.75rem);
      line-height: 0.95;
    }

    .collection-hero__copy > p:not(.collection-hero__eyebrow) {
      max-width: 31rem;
      font-size: 1.05rem;
      line-height: 1.32;
    }

    .section--collection-hero .section-content-wrapper > .group-block:last-child .group-block-content {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
      gap: 0.75rem 1rem;
      max-width: 34rem;
    }

    .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
      gap: 0.45rem;
      min-width: 0;
      width: 100%;
      font-size: 0.8rem;
      line-height: 1.15;
    }

    .section--collection-hero .section-content-wrapper > .group-block:last-child .text-block::before {
      width: 1rem;
      height: 1rem;
    }
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .group-block-content {
    gap: var(--gap-md);
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: var(--gap-md);
    align-items: start;
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block::before {
    content: '';
    grid-row: 1 / span 2;
    width: 3rem;
    height: 3rem;
    margin-block-start: 0.1rem;
    border-radius: var(--style-border-radius-sm);
    background-color: rgb(var(--color-foreground-rgb) / 0.08);
    background-position: center;
    background-repeat: no-repeat;
    background-size: 1.9rem;
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block:nth-child(1)::before {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%232d3730' stroke-width='1.9' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M21 8.5 12 3 3 8.5l9 5.5 9-5.5Z'/%3E%3Cpath d='M3 8.5V16l9 5 9-5V8.5'/%3E%3Cpath d='M12 14v7'/%3E%3Cpath d='m7.5 5.75 9 5.5'/%3E%3C/svg%3E");
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block:nth-child(2)::before {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%232d3730' stroke-width='1.9' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M3 10.5 12 3l9 7.5'/%3E%3Cpath d='M5.5 9v11h13V9'/%3E%3Cpath d='M9 20v-6h6v6'/%3E%3Cpath d='M8 10.5h1.5'/%3E%3Cpath d='M14.5 10.5H16'/%3E%3C/svg%3E");
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block:nth-child(3)::before {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' fill='none' stroke='%232d3730' stroke-width='1.9' stroke-linecap='round' stroke-linejoin='round' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 7v5h-5'/%3E%3Cpath d='M4 17v-5h5'/%3E%3Cpath d='M18.2 11A6.5 6.5 0 0 0 7.1 7.4L4 10'/%3E%3Cpath d='M5.8 13A6.5 6.5 0 0 0 16.9 16.6L20 14'/%3E%3C/svg%3E");
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block :is(h1, h2, h3, h4, h5, h6, p) {
    grid-column: 2;
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block :is(h1, h2, h3, h4, h5, h6) {
    margin-block-start: 0;
  }

  .section--starter-feature .section-content-wrapper > .group-block:last-child .text-block p {
    margin-block-end: 0;
  }

  .section--problem-solution .section-content-wrapper > .group-block:first-child {
    position: relative;
  }

  .section--problem-solution .section-content-wrapper > .group-block:first-child::before {
    content: 'Fragrance guide';
    display: inline-flex;
    width: fit-content;
    margin-block-end: var(--gap-sm);
    padding: 0.35rem 0.6rem;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.16);
    border-radius: 999px;
    color: rgb(var(--color-foreground-rgb) / 0.74);
    font-family: var(--font-subheading--family);
    font-size: 0.78rem;
    font-weight: var(--font-subheading--weight);
    text-transform: uppercase;
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .group-block-content {
    gap: var(--gap-sm);
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .text-block {
    display: grid;
    grid-template-columns: 2.6rem minmax(0, 1fr);
    column-gap: var(--gap-md);
    align-items: start;
    padding: var(--gap-md) var(--gap-lg);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.12);
    border-radius: var(--style-border-radius-sm);
    background: rgb(255 255 255 / 0.66);
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .text-block::before {
    display: grid;
    place-items: center;
    width: 1.75rem;
    height: 1.75rem;
    margin-block-start: 0.28em;
    border-radius: 999px;
    background: var(--color-primary);
    color: var(--color-primary-button-text);
    font-family: var(--font-subheading--family);
    font-size: 0.9rem;
    font-weight: var(--font-subheading--weight);
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .text-block:nth-child(1)::before {
    content: '1';
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .text-block:nth-child(2)::before {
    content: '2';
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .text-block:nth-child(3)::before {
    content: '3';
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .text-block h3 {
    grid-column: 2;
    margin-block-start: 0;
  }

  .section--problem-solution .section-content-wrapper > .group-block:last-child .text-block p {
    grid-column: 2;
    margin-block-end: 0;
  }
{% endstylesheet %}
